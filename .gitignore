# .gitignore for oh-agent-browser-sidecar

# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test
coverage/
.nyc_output/

# Session data (should not be committed)
sessions/
*.json.enc

# Temporary files
tmp/
temp/

# Sisyphus internal files
.sisyphus/