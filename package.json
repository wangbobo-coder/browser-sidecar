{
  "name": "@oh-agent/browser-sidecar",
  "version": "1.0.1",
  "description": "Kubernetes Sidecar browser automation tool for OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser",
    "automation",
    "sidecar",
    "kubernetes",
    "playwright",
    "openclaw",
    "puppeteer",
    "browser-automation",
    "session-management",
    "web-scraping"
  ],
  "author": "oh-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangbobo-coder/browser-sidecar.git"
  },
  "bugs": {
    "url": "https://github.com/wangbobo-coder/browser-sidecar/issues"
  },
  "homepage": "https://github.com/wangbobo-coder/browser-sidecar#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@eslint/js": "^9.0.0"
  }
}
